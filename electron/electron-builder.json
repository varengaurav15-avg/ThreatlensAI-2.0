{
  "appId": "com.threatlens.ai",
  "productName": "ThreatLens AI",
  "forceCodeSigning": false,
  "directories": {
    "output": "dist-installers"
  },
  "files": [
    "main.js",
    "preload.js",
    "assets/**"
  ],
  "extraResources": [
    {
      "from": "../backend",
      "to": "backend",
      "filter": ["**/*", "!venv/**", "!__pycache__/**", "!*.pyc"]
    },
    {
      "from": "../frontend/dist",
      "to": "frontend-dist"
    }
  ],
  "win": {
    "target": "dir",
    "icon": "assets/icon.ico",
    "verifyUpdateCodeSignature": false
  }
}